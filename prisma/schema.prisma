// prisma/schema.prisma
// ORMS — Ordinance and Resolution Management System

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              Int       @id @default(autoincrement())
  name            String
  email           String    @unique
  password        String
  role            String    @default("Staff")
  departmentId    Int?
  isActive        Boolean   @default(true)
  emailVerifiedAt DateTime?
  rememberToken   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  department          Department?  @relation(fields: [departmentId], references: [id])
  createdOrdinances   Ordinance[]  @relation("OrdinanceCreator")
  updatedOrdinances   Ordinance[]  @relation("OrdinanceUpdater")
  createdResolutions  Resolution[] @relation("ResolutionCreator")
  updatedResolutions  Resolution[] @relation("ResolutionUpdater")
  uploadedDocuments   Document[]   @relation("DocumentUploader")
  approvedDocuments   Document[]   @relation("DocumentApprover")
  auditLogs           AuditLog[]

  @@index([isActive, role])
  @@map("users")
}

model Department {
  id          Int      @id @default(autoincrement())
  name        String
  code        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  ordinances  Ordinance[]
  resolutions Resolution[]
  documents   Document[]

  @@index([isActive, name])
  @@map("departments")
}

// An ordinance is a direct request to the Mayor — anyone from the
// municipality can file one. No hearings, no vote: if the Mayor approves
// the request, a MOA follows immediately.
// Lifecycle: request_received → approved | declined.
model Ordinance {
  id                Int      @id @default(autoincrement())
  ordinanceNumber   String   @unique
  title             String
  year              Int
  who               String?
  what              String?
  when              DateTime?
  where             String?
  why               String?
  how               String?
  requestedBy       String?
  requestReceivedAt DateTime?
  decidedAt         DateTime?
  remarks           String?
  departmentId      Int
  status            String   @default("request_received")
  summary           String?
  notes             String?
  createdBy         Int
  updatedBy         Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  department  Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  creator     User       @relation("OrdinanceCreator", fields: [createdBy], references: [id])
  updater     User       @relation("OrdinanceUpdater", fields: [updatedBy], references: [id])
  documents   Document[]


  @@index([year, status])
  @@index([departmentId, status])
  @@index([ordinanceNumber, year])
  @@map("ordinances")
}

// A resolution is a term-based measure that originates as a request from
// another office (usually endorsed by the Mayor's Office with a letter).
// Lifecycle: request_received → calendared → in_committee → for_adoption
// → adopted | not_adopted → signed. See types/index.ts for the state notes.
model Resolution {
  id                      Int      @id @default(autoincrement())
  resolutionNumber        String   @unique
  title                   String
  year                    Int
  term                    String?
  who                     String?
  what                    String?
  when                    DateTime?
  where                   String?
  why                     String?
  how                     String?
  requestedBy             String?
  requestReceivedAt       DateTime?
  endorsedByMayor         Boolean  @default(false)
  responsibleDepartmentId Int
  status                  String   @default("request_received")
  summary                 String?
  remarks                 String?
  adoptedAt               DateTime?
  signedAt                DateTime?
  requesterNotifiedAt     DateTime?
  createdBy               Int
  updatedBy               Int
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  responsibleDepartment Department          @relation(fields: [responsibleDepartmentId], references: [id])
  creator               User                @relation("ResolutionCreator", fields: [createdBy], references: [id])
  updater               User                @relation("ResolutionUpdater", fields: [updatedBy], references: [id])
  documents             Document[]
  calendarItems         CalendarItem[]
  referrals             CommitteeReferral[]

  @@index([year, status])
  @@index([responsibleDepartmentId, status])
  @@index([status, createdAt])
  @@map("resolutions")
}

// One of the 11 standing committees of the Sangguniang Bayan.
model Committee {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members   CommitteeMember[]
  referrals CommitteeReferral[]

  @@map("committees")
}

// Committee composition: 1 Chairman, 1 Vice_Chairman, 3 Members.
// Members are stored by name — SB members are viewers, not actors, so they
// need not exist as user accounts.
model CommitteeMember {
  id          Int      @id @default(autoincrement())
  committeeId Int
  name        String
  position    String   // Chairman | Vice_Chairman | Member
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  committee Committee @relation(fields: [committeeId], references: [id], onDelete: Cascade)

  @@index([committeeId])
  @@map("committee_members")
}

// An entry on the Calendar of Business — the agenda of a regular session.
// A resolution appears twice: once for referral (first take-up) and once
// for adoption (acting on the committee report).
model CalendarItem {
  id           Int      @id @default(autoincrement())
  resolutionId Int
  purpose      String   // referral | adoption
  sessionDate  DateTime
  remarks      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  resolution Resolution @relation(fields: [resolutionId], references: [id], onDelete: Cascade)

  @@index([sessionDate])
  @@index([resolutionId])
  @@map("calendar_items")
}

// Referral of a resolution to a standing committee, and the committee
// report (findings + recommendation) that comes back for adoption.
model CommitteeReferral {
  id                Int      @id @default(autoincrement())
  resolutionId      Int
  committeeId       Int
  referredAt        DateTime @default(now())
  hearingHeldAt     DateTime?
  reportFindings    String?
  reportRecommendation String?
  reportSubmittedAt DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  resolution Resolution @relation(fields: [resolutionId], references: [id], onDelete: Cascade)
  committee  Committee  @relation(fields: [committeeId], references: [id])

  @@index([resolutionId])
  @@index([committeeId])
  @@map("committee_referrals")
}

model Document {
  id               Int      @id @default(autoincrement())
  filename         String
  filePath         String
  fileSize         Int
  mimeType         String
  documentType     String?
  title            String?
  description      String?
  version          Int      @default(1)
  isLatestVersion  Boolean  @default(true)
  remarks          String?
  departmentId     Int?
  ordinanceId      Int?
  resolutionId     Int?
  parentDocumentId Int?
  uploadedBy       Int
  approvedBy       Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  department     Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  ordinance      Ordinance?  @relation(fields: [ordinanceId], references: [id], onDelete: SetNull)
  resolution     Resolution? @relation(fields: [resolutionId], references: [id], onDelete: SetNull)
  parentDocument Document?   @relation("DocumentVersions", fields: [parentDocumentId], references: [id], onDelete: SetNull)
  childDocuments Document[]  @relation("DocumentVersions")
  uploader       User        @relation("DocumentUploader", fields: [uploadedBy], references: [id], onDelete: Cascade)
  approver       User?       @relation("DocumentApprover", fields: [approvedBy], references: [id], onDelete: SetNull)


  @@index([ordinanceId, createdAt])
  @@index([departmentId, createdAt])
  @@index([documentType])
  @@index([isLatestVersion])
  @@map("documents")
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  userId      Int?
  action      String
  tableName   String
  recordId    Int
  oldValues   String?
  newValues   String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tableName, recordId])
  @@index([userId])
  @@map("audit_logs")
}
